# =====================================================================
# Timea Skincare - environment variables (placeholders only)
# Copy this file to ".env.local" and fill in real values.
# NEVER commit real secrets. .env / .env.local are gitignored.
# =====================================================================

# --- SMS reservation notifications (REQUIRED for SMS to work) ---------
# Provider: Twilio (https://www.twilio.com) - SMS_PROVIDER_* map to the
# Twilio Account SID, Auth Token and a verified sender number.
SMS_PROVIDER_ACCOUNT_ID=
SMS_PROVIDER_AUTH_TOKEN=
SMS_PROVIDER_FROM_NUMBER=
# Salon owner phone that receives the "new reservation" SMS.
# Currently a TEST number; replace later with Timea's real salon phone.
SALON_OWNER_PHONE="+421949150463"

# --- Google Calendar integration (optional) --------------------------
# If empty, the reservation still works as a request (SMS only).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# --- E-mail confirmation via Resend (optional) -----------------------
RESEND_API_KEY=
BOOKING_FROM_EMAIL="Timea Skincare <rezervacie@timeaskincare.sk>"

# --- Reservation confirmation links ----------------------------------
# Secret used to sign reservation confirm/decline tokens (HMAC). Set a long
# random value in production. If empty, RESEND_API_KEY / CRON_SECRET are used
# as a fallback so the flow still works.
BOOKING_SIGNING_SECRET=
# Absolute site URL used to build confirm/decline links in e-mails.
# Defaults to https://timeaskincare.sk when empty.
NEXT_PUBLIC_SITE_URL="https://timeaskincare.sk"

# --- Legacy SMS variable names (still supported as fallback) ----------
# SMS_PROVIDER_* above take priority. These remain for backward compat.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TIMEA_NOTIFICATION_PHONE=

# --- Protect /api/booking/reminders cron endpoint --------------------
CRON_SECRET=
